# Public HTTP listen address (business endpoints)
APP_ADDR=:8080

# Internal admin address (metrics + health probes); keep off the public network
METRICS_ADDR=:9090

# PostgreSQL connection string
DATABASE_URL=postgres://postgres:postgres@localhost:5432/transfers?sslmode=disable

# Connection pool size
DB_MAX_CONNS=10

# Run SQL migrations on startup (true/false)
RUN_MIGRATIONS=true

# Graceful shutdown budget in seconds
SHUTDOWN_TIMEOUT_SECONDS=15

# Log level: debug, info, warn, error
LOG_LEVEL=info

# Optional: also write JSON logs to this file (empty = stdout only)
LOG_FILE=

# Used only by integration tests (make test-integration). Point this at a
# DEDICATED, throwaway database — the tests TRUNCATE all tables on each run.
# Must NOT be the same database as DATABASE_URL above.
TEST_DATABASE_URL=postgres://postgres:postgres@localhost:5432/transfers_test?sslmode=disable
