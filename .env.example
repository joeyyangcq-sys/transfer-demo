# HTTP listen address
APP_ADDR=:8080

# PostgreSQL connection string
DATABASE_URL=postgres://postgres:postgres@localhost:5432/transfers?sslmode=disable

# Connection pool size
DB_MAX_CONNS=10

# Run SQL migrations on startup (true/false)
RUN_MIGRATIONS=true

# Graceful shutdown budget in seconds
SHUTDOWN_TIMEOUT_SECONDS=15

# Log level: debug, info, warn, error
LOG_LEVEL=info

# Used only by integration tests (make test-integration)
TEST_DATABASE_URL=postgres://postgres:postgres@localhost:5432/transfers?sslmode=disable
