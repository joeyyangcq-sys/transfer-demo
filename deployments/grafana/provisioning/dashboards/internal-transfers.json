{
  "title": "Internal Transfers",
  "uid": "internal-transfers",
  "tags": ["internal-transfers"],
  "timezone": "browser",
  "schemaVersion": 39,
  "refresh": "5s",
  "time": { "from": "now-30m", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "rate_window",
        "type": "custom",
        "label": "Rate window",
        "query": "1m,5m,15m",
        "current": { "text": "5m", "value": "5m" },
        "options": [
          { "text": "1m", "value": "1m", "selected": false },
          { "text": "5m", "value": "5m", "selected": true },
          { "text": "15m", "value": "15m", "selected": false }
        ]
      }
    ]
  },
  "panels": [
    { "id": 100, "type": "row", "title": "Overview", "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 } },
    {
      "id": 1, "type": "stat", "title": "Transfers completed",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "area" },
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "green" } }, "overrides": [] },
      "targets": [ { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(transfers_total{status=\"completed\"})", "legendFormat": "completed" } ]
    },
    {
      "id": 2, "type": "stat", "title": "Transfers failed",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 1 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "area" },
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "red" } }, "overrides": [] },
      "targets": [ { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(transfers_total{status=\"failed\"})", "legendFormat": "failed" } ]
    },
    {
      "id": 3, "type": "stat", "title": "Accounts created (ok)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 1 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "area" },
      "targets": [ { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(accounts_created_total{result=\"ok\"})", "legendFormat": "ok" } ]
    },
    {
      "id": 4, "type": "stat", "title": "HTTP req/s",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 1 },
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "area" },
      "targets": [ { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(rate(http_requests_total[$rate_window]))", "legendFormat": "req/s" } ]
    },

    { "id": 101, "type": "row", "title": "HTTP (RED)", "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 } },
    {
      "id": 10, "type": "timeseries", "title": "Request rate (by route/status)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "targets": [ { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum by (route,status) (rate(http_requests_total[$rate_window]))", "legendFormat": "{{route}} {{status}}" } ]
    },
    {
      "id": 11, "type": "timeseries", "title": "Request latency (p50/p95/p99)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "histogram_quantile(0.50, sum by (le) (rate(http_request_duration_seconds_bucket[$rate_window])))", "legendFormat": "p50" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "histogram_quantile(0.95, sum by (le) (rate(http_request_duration_seconds_bucket[$rate_window])))", "legendFormat": "p95" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "histogram_quantile(0.99, sum by (le) (rate(http_request_duration_seconds_bucket[$rate_window])))", "legendFormat": "p99" }
      ]
    },

    { "id": 102, "type": "row", "title": "Transfers", "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 } },
    {
      "id": 20, "type": "timeseries", "title": "Transfer rate (by status)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 15 },
      "fieldConfig": { "defaults": { "unit": "ops", "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "targets": [ { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum by (status) (rate(transfers_total[$rate_window]))", "legendFormat": "{{status}}" } ]
    },
    {
      "id": 21, "type": "timeseries", "title": "Transfer processing latency (p50/p95/p99)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 15 },
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "histogram_quantile(0.50, sum by (le) (rate(transfer_processing_duration_seconds_bucket[$rate_window])))", "legendFormat": "p50" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "histogram_quantile(0.95, sum by (le) (rate(transfer_processing_duration_seconds_bucket[$rate_window])))", "legendFormat": "p95" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "histogram_quantile(0.99, sum by (le) (rate(transfer_processing_duration_seconds_bucket[$rate_window])))", "legendFormat": "p99" }
      ]
    },
    {
      "id": 22, "type": "timeseries", "title": "Idempotency requests (by key presence)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 15 },
      "fieldConfig": { "defaults": { "unit": "ops", "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "targets": [ { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum by (result) (rate(idempotency_requests_total[$rate_window]))", "legendFormat": "{{result}}" } ]
    },

    { "id": 103, "type": "row", "title": "Errors & Accounts", "gridPos": { "h": 1, "w": 24, "x": 0, "y": 23 } },
    {
      "id": 30, "type": "timeseries", "title": "Errors (by type)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 24 },
      "fieldConfig": { "defaults": { "unit": "ops", "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "targets": [ { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum by (type) (rate(transfers_errors_total[$rate_window]))", "legendFormat": "{{type}}" } ]
    },
    {
      "id": 31, "type": "timeseries", "title": "Errors (by layer)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 24 },
      "fieldConfig": { "defaults": { "unit": "ops", "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "targets": [ { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum by (layer) (rate(transfers_errors_total[$rate_window]))", "legendFormat": "{{layer}}" } ]
    },
    {
      "id": 32, "type": "timeseries", "title": "Accounts created (by result)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 24 },
      "fieldConfig": { "defaults": { "unit": "ops", "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "targets": [ { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum by (result) (rate(accounts_created_total[$rate_window]))", "legendFormat": "{{result}}" } ]
    },

    { "id": 104, "type": "row", "title": "Runtime & Database", "gridPos": { "h": 1, "w": 24, "x": 0, "y": 32 } },
    {
      "id": 40, "type": "timeseries", "title": "DB pool connections",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 33 },
      "fieldConfig": { "defaults": { "unit": "none", "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "db_pool_total_conns", "legendFormat": "total" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "db_pool_idle_conns", "legendFormat": "idle" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "db_pool_acquired_conns", "legendFormat": "acquired" }
      ]
    },
    {
      "id": 41, "type": "timeseries", "title": "Goroutines",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 33 },
      "fieldConfig": { "defaults": { "unit": "none", "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "targets": [ { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "go_goroutines", "legendFormat": "goroutines" } ]
    },
    {
      "id": 42, "type": "timeseries", "title": "Memory (heap in-use / RSS)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 33 },
      "fieldConfig": { "defaults": { "unit": "bytes", "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "go_memstats_heap_inuse_bytes", "legendFormat": "heap in-use" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "process_resident_memory_bytes", "legendFormat": "RSS" }
      ]
    }
  ]
}
